load("@build_bazel_rules_swift//swift:swift_library.bzl", "swift_library")

swift_library(
    name = "InternalCollectionsUtilities",
    srcs = glob(
        ["Sources/InternalCollectionsUtilities/**/*.swift"],
        exclude = ["Sources/InternalCollectionsUtilities/**/*.gyb"],
    ),
    module_name = "InternalCollectionsUtilities",
    visibility = ["//visibility:public"],
)

swift_library(
    name = "DequeModule",
    srcs = glob(["Sources/DequeModule/**/*.swift"]),
    module_name = "DequeModule",
    visibility = ["//visibility:public"],
    deps = [":InternalCollectionsUtilities"],
)
